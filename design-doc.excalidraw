      "boundElements": [],
      "updated": 1774589826274,
      "link": null,
      "locked": false,
      "text": "get /api/v1/cart : get all the products from cart\npost /api/v1/cart  : add product to the cart\ndelete /api/v1/cart: delete the product from the cart\npatch /api/v1/cart/productid : update or modify the quantity of the product\npost /api/v1/cart/checkout : checking out the cart : address shipping all these details,payment method (will work on this later)\npost /api/v1/cart/payment : redirect to payment gateway.\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "get /api/v1/cart : get all the products from cart\npost /api/v1/cart  : add product to the cart\ndelete /api/v1/cart: delete the product from the cart\npatch /api/v1/cart/productid : update or modify the quantity of the product\npost /api/v1/cart/checkout : checking out the cart : address shipping all these details,payment method (will work on this later)\npost /api/v1/cart/payment : redirect to payment gateway.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
